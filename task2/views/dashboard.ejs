<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Дашборд преподавателя</h1>
            <nav>
                <a href="/feedback">Оставить отзыв</a>
                <a href="/dashboard" class="active">Дашборд</a>
                <a href="/all-feedback">Все отзывы</a>
            </nav>
        </header>
        
        <main>
            <div class="stats-grid">
                <div class="stat-card">
                    <h3>Всего отзывов</h3>
                    <div class="stat-value"><%= totalFeedbacks %></div>
                </div>
                
                <div class="stat-card">
                    <h3>Средняя оценка</h3>
                    <div class="stat-value">
                        <%= averageRating %>
                        <span class="stat-unit">/ 5</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <h3>Всего оценок</h3>
                    <div class="stat-value"><%= totalRatings %></div>
                </div>
            </div>
            
            <div class="rating-distribution">
                <h2>Распределение оценок</h2>
                <div class="distribution-bars">
                    <% for (let i = 1; i <= 5; i++) { 
                        let percentage = totalRatings > 0 ? (ratingDistribution[i] / totalRatings * 100) : 0;
                    %>
                        <div class="distribution-item">
                            <div class="rating-label"><%= i %> ★</div>
                            <div class="bar-container">
                                <div class="bar" style="--width: <%= percentage %>"></div>
                            </div>
                            <div class="rating-count"><%= ratingDistribution[i] %></div>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <div class="additional-stats">
                <h2>Дополнительная статистика</h2>
                <ul>
                    <li>Отзывов с текстовыми комментариями: <%= totalFeedbacks %></li>
                    <li>Процент заполнения формы: 100%</li>
                </ul>
            </div>
        </main>
        
        <footer>
            <p>Система сбора обратной связи &copy; 2024</p>
        </footer>
    </div>
</body>
</html>