<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1><%= title %></h1>
            <nav>
                <a href="/feedback">Оставить отзыв</a>
                <a href="/dashboard">Дашборд</a>
                <a href="/all-feedback">Все отзывы</a>
            </nav>
        </header>
        
        <main>
            <div class="error-message">
                <div class="error-icon">⚠️</div>
                <h2><%= message %></h2>
                <div class="actions">
                    <a href="/feedback" class="btn">Вернуться к форме</a>
                </div>
            </div>
        </main>
        
        <footer>
            <p>Система сбора обратной связи &copy; 2024</p>
        </footer>
    </div>
</body>
</html>