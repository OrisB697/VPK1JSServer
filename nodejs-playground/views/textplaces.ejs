<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Лабораторная работа №2 ТРСЧВП">
    <link rel="stylesheet" href="/style.css">
    <title>Laba 2</title>
</head>


<body>
    <header>
        <h1>ТЕКСТОВЫЕ ОТВЕТЫ</h1>
    </header>

    <main class="textplace-main">
        <%
        const textNumbers = [3, 4, 5, 6];
        const ansUser = {};

        for(let i = 0; i < data.length; i++) {%>
            <section class="user-text">
                <p>Пользователь <%=i + 1 %></p>

            <% textNumbers.forEach(tNum => {
                const key = tNum.toString();%>
                <p class="title-for-q">Вопрос № <%=tNum %></p>
                <p><%=data[i].answers[key]  %></p>
            <%})%>
            </section>
        <%}



        %>
    </main>
    <footer>
        <p>2026 Нагорский Б. Н.</p>
        <p>КТбо3-7</p>
    </footer>
</body>
</html>